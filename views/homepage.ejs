<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>home page</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400..900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="./style.css" />
  </head>
  <body>
    <section class="hero">
    <div class="brand">
      <img src="/images/logo.jpg" width="40" height="40" alt="" />
      <span class="name">LAW SOCIETY</span>
    </div>
    <nav class="navbar">
      <a href="#">Register</a>
      <a href="#">Contact Us</a>
    </nav>

    <div class="hero-cont">
      <h1 class="line">MOOT COURT</h1>
      <h1 class="line">COMPETITION 2026</h1>
      <h3 class="hero-para">
        Challenge your advocacy, legal research, and oral argument skills in a
        prestigious moot court competition designed to prepare future legal
        professionals.
      </h3>

      <br>
      <br>
      <br>
      <a href="#" type="button" class="btn">
        Register
      </a>
    </div>
    </section>

    <section class="sec2">

    <div class="whyjoin">
        <h1 class="line2">WHY JOIN MOOT COURT?</h1>
        <div class="outercard">
            <div class="topleft">
                <h2>Master the Art of Advocacy</h2>
                
            </div>
            <div class="topright">
                <h2>Develop Strategic Thinking</h2>
            </div>
            <div class="bottomleft">
                <h2>Command the Courtroom</h2>
            </div>
            <div class="bottomright">
                <h2>Lead Through Persuasion</h2>
            </div>
        </div>
    </div>
    </section>

    <section class="timeline-section">

    <h1 class="timeline-heading">
        COMPETITION JOURNEY
    </h1>

    <div class="timeline-container">

        <div class="timeline-card card1">
            <span>01</span>
            <h2>Register</h2>
        </div>

        <div class="timeline-card card2">
            <span>02</span>
            <h2>Research the Case</h2>
        </div>

        <div class="timeline-card card3">
            <span>03</span>
            <h2>Find Evidence</h2>
        </div>

        <div class="timeline-card card4">
            <span>04</span>
            <h2>Prepare Arguments</h2>
        </div>

        <div class="timeline-card card5">
            <span>05</span>
            <h2>Cross Examination</h2>
        </div>

        <div class="timeline-card card6">
            <span>06</span>
            <h2>Present Before The Bench</h2>
        </div>

    </div>

</section>

    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>
    <script src="./script.js"></script>
  </body>
</html>
